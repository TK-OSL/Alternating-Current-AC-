                        <div class="font-mono text-center my-2 text-xl bg-slate-50 p-3 rounded-lg border border-slate-200 math-font">
                            v(t) = V<sub>p</sub> sin(&omega;t)
                        </div>
                        <div class="font-mono text-center my-2 text-xl bg-slate-50 p-3 rounded-lg border border-slate-200 math-font">
                            i(t) = I<sub>p</sub> sin(&omega;t)

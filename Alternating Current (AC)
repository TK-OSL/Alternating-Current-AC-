        /**
         * Initializes and scales the dynamic D3 SVG element canvas. Called once on initialization and on window resizes.
         * @param {number} newWidth - Width of the host container element
         * @param {number} newHeight - Height of the host container element
         */
        function initChart(newWidth, newHeight) {
            if (!newWidth || !newHeight) return;

            // Offset inner plot space using margin vectors
            width = newWidth - margin.left - margin.right;
            height = newHeight - margin.top - margin.bottom;

            // Clear legacy SVGs
            d3.select("#graph-container").selectAll("svg").remove();

            // Append SVG to container DOM
            svg = d3.select("#graph-container")
                .append("svg")
                .attr("width", width + margin.left + margin.right)
                .attr("height", height + margin.top + margin.bottom)
                .append("g")
                .attr("transform", `translate(${margin.left},${margin.top})`);

            // Scaling functions map numerical ranges to Cartesian screen space pixels
            xScale = d3.scaleLinear().range([0, width]);
            yScaleV = d3.scaleLinear().range([height, 0]);
            yScaleI = d3.scaleLinear().range([height, 0]);

            // Draw operational background gridlines
            svg.append("g").attr("class", "grid").attr("opacity", 0.08).attr("transform", `translate(0,${height/2})`).call(d3.axisBottom(xScale).tickSize(-height/2).tickFormat(""));
            svg.append("g").attr("class", "grid").attr("opacity", 0.08).call(d3.axisLeft(yScaleV).tickSize(-width).tickFormat(""));

            // Initialize visual axes groups
            xAxis = svg.append("g").attr("class", "text-slate-500 font-mono text-xs");
            yAxisLeft = svg.append("g").attr("class", "text-blue-600 font-mono text-xs");
            yAxisRight = svg.append("g").attr("transform", `translate(${width},0)`).attr("class", "text-red-600 font-mono text-xs");

            // Line plotting generators
            lineV = d3.line().x(d => xScale(d.time)).y(d => yScaleV(d.value)).curve(d3.curveBasis);
            lineI = d3.line().x(d => xScale(d.time)).y(d => yScaleI(d.value)).curve(d3.curveBasis);

            // Path templates for static backdrop wave previews
            svg.append("path").attr("class", "bg-path-v").attr("fill", "none").attr("stroke", "#3b82f6").attr("stroke-width", 2).attr("opacity", 0.15).attr("stroke-dasharray", "4,4");
            svg.append("path").attr("class", "bg-path-i").attr("fill", "none").attr("stroke", "#ef4444").attr("stroke-width", 2).attr("opacity", 0.15).attr("stroke-dasharray", "4,4");

            // Active path templates for real-time progressive wave coloring
            svg.append("path").attr("class", "active-path-v").attr("fill", "none").attr("stroke", "#2563eb").attr("stroke-width", 3.5);
            svg.append("path").attr("class", "active-path-i").attr("fill", "none").attr("stroke", "#dc2626").attr("stroke-width", 3.5);

            // Interactive oscilloscope dynamic sweep indicators
            const markerG = svg.append("g");
            markerG.append("line").attr("class", "time-line").attr("stroke", "#94a3b8").attr("stroke-width", 1.5).attr("stroke-dasharray", "3,3").attr("y1", 0).attr("y2", height);
            markerG.append("circle").attr("class", "dot-v").attr("r", 5).attr("fill", "#fff").attr("stroke", "#2563eb").attr("stroke-width", 2);
            markerG.append("circle").attr("class", "dot-i").attr("r", 5).attr("fill", "#fff").attr("stroke", "#dc2626").attr("stroke-width", 2);

            // Labels setup
            svg.append("text").attr("transform", "rotate(-90)").attr("y", -margin.left + 15).attr("x", -(height/2)).attr("dy", "1em").style("text-anchor", "middle").attr("class", "label-v text-xs fill-blue-600 font-bold").text(translations[currentLang].voltage);
            svg.append("text").attr("transform", "rotate(-90)").attr("y", width + margin.right - 25).attr("x", -(height/2)).attr("dy", "1em").style("text-anchor", "middle").attr("class", "label-i text-xs fill-red-600 font-bold").text(translations[currentLang].current);
            svg.append("text").attr("transform", `translate(${width/2}, ${height + margin.bottom - 5})`).style("text-anchor", "middle").attr("class", "label-time text-xs fill-slate-500 font-bold").text(translations[currentLang].labelTime);
        }

        /**
         * Re-adjusts domains dynamically based on frequency and maximum computed peak amplitudes
         * @param {number} Ip - Maximum current peak in Amps
         * @param {number} freq - AC Frequency in Hz
         */
        function updateChartScales(Ip, freq) {
            if (!xScale) return;
            const period = 1 / freq;
            const tMax = period * numPeriodsToShow;

            xScale.domain([0, tMax]);
            yScaleV.domain([-380, 380]); 
            const iMaxScale = Math.max(1.0, Ip * 1.5); 
            yScaleI.domain([-iMaxScale, iMaxScale]);

            xAxis.call(d3.axisBottom(xScale).ticks(6).tickFormat(d3.format(".3f")));
            yAxisLeft.call(d3.axisLeft(yScaleV).ticks(5));
            yAxisRight.call(d3.axisRight(yScaleI).ticks(5));
            xAxis.attr("transform", `translate(0,${yScaleV(0)})`);
        }

        /**
         * Builds array of coordinates representing static Sine Wave trajectories
         */
        function generateStaticData() {
            dataV = []; dataI = [];
            const tMax = (1 / f) * numPeriodsToShow;
            const omega = 2 * Math.PI * f;
            const Ip = Vp / R;

            for (let i = 0; i <= numPoints; i++) {
                const timeStr = (i / numPoints) * tMax;
                dataV.push({ time: timeStr, value: Vp * Math.sin(omega * timeStr) });
                dataI.push({ time: timeStr, value: Ip * Math.sin(omega * timeStr) });
            }
        }

        /**
         * Binds calculated static coordinates arrays to background D3 paths
         */
        function drawPaths() {
            if (svg && dataV.length > 0) {
                svg.select(".bg-path-v").datum(dataV).attr("d", lineV);
                svg.select(".bg-path-i").datum(dataI).attr("d", lineI);
            }
        }

        let lastTime = 0;
        /**
         * Continuously triggers browser layout redrawing for the dynamic sweeps
         * @param {number} currentTime - Absolute timestamp from performance.now()
         */
        function animate(currentTime) {
            if (!lastTime) lastTime = currentTime;
            const deltaTime = (currentTime - lastTime) / 1000; 
            lastTime = currentTime;

            if (isPlaying && svg && width > 0) {
                const period = 1 / f;
                t += (deltaTime * period * simSpeed * 0.4); 
                
                const tMax = period * numPeriodsToShow;
                if (t > tMax) t = t % tMax;

                const omega = 2 * Math.PI * f;
                const Ip = Vp / R;
                const currentV = Vp * Math.sin(omega * t);
                const currentI = Ip * Math.sin(omega * t);

                const activeDataV = dataV.filter(d => d.time <= t);
                const activeDataI = dataI.filter(d => d.time <= t);

                // Append local coordinates tracking active time
                activeDataV.push({time: t, value: currentV});
                activeDataI.push({time: t, value: currentI});

                // Update active coloring vectors
                svg.select(".active-path-v").datum(activeDataV).attr("d", lineV);
                svg.select(".active-path-i").datum(activeDataI).attr("d", lineI);

                // Shift marker pointers
                const xPos = xScale(t);
                svg.select(".time-line").attr("x1", xPos).attr("x2", xPos);
                svg.select(".dot-v").attr("cx", xPos).attr("cy", yScaleV(currentV));
                svg.select(".dot-i").attr("cx", xPos).attr("cy", yScaleI(currentI));
            }
            animationFrameId = requestAnimationFrame(animate);
        }

        /**
         * Toggles control board modes (Synced to Live Simulation / Decoupled Custom Board)
         */
        function updateExerciseModeUI() {
            isSyncedWithSim = elements.syncToggle.checked;
            const strings = translations[currentLang];
            
            if (isSyncedWithSim) {
                elements.manualControls.classList.add('hidden');
                elements.exModeIndicator.innerText = strings.indicatorLinked;
                elements.exModeIndicator.className = "text-[10px] bg-blue-100 text-blue-700 px-2 py-0.5 rounded font-bold uppercase transition-all-300";
            } else {
                elements.manualControls.classList.remove('hidden');
                elements.exModeIndicator.innerText = strings.indicatorDecoupled;
                elements.exModeIndicator.className = "text-[10px] bg-amber-100 text-amber-700 px-2 py-0.5 rounded font-bold uppercase transition-all-300";
            }
        }

        /**
         * Generates physical randomized numbers for exercise practices
         * Standard real-world standard values are preferred for pedagogical clarity.
         */
        function randomizeExerciseValues() {
            // Decouple immediately on request
            elements.syncToggle.checked = false;
            updateExerciseModeUI();

            // Set of common classroom alternating voltages (peak value equivalents)
            const commonVoltPeaks = [110, 120, 170, 220, 311, 325, 340, 380];
            // Set of clean, easy-to-calculate load resistances
            const commonResistances = [10, 20, 40, 50, 100, 200, 220, 250, 500];

            const randomVp = commonVoltPeaks[Math.floor(Math.random() * commonVoltPeaks.length)];
            const randomR = commonResistances[Math.floor(Math.random() * commonResistances.length)];

            // Set to manual numeric input fields
            elements.manualVp.value = randomVp;
            elements.manualR.value = randomR;

            // Trigger updates
            updateCalculations();
        }

        // Bind dynamic listeners on simulator inputs
        [elements.vInput, elements.fInput, elements.rInput, elements.speedInput].forEach(input => {
            input.addEventListener('input', updateCalculations);
        });

        // Bind manual inputs for math exercises
        [elements.manualVp, elements.manualR].forEach(input => {
            input.addEventListener('input', () => {
                // Instantly update if user alters values directly
                updateCalculations();
            });
        });

        // Checkbox tracker for syncing toggles
        elements.syncToggle.addEventListener('change', () => {
            updateExerciseModeUI();
            updateCalculations();
        });

        // Attach action click to math randomized generator
        elements.btnRandomize.addEventListener('click', randomizeExerciseValues);

        // Manage play-pause states
        elements.playPauseBtn.addEventListener('click', () => {
            isPlaying = !isPlaying;
            elements.playIcon.classList.toggle('hidden', isPlaying);
            elements.pauseIcon.classList.toggle('hidden', !isPlaying);
            if (isPlaying) lastTime = performance.now();
        });

        // ResizeObserver implementation to guarantee responsive redraw of D3 elements
        const resizeObserver = new ResizeObserver(entries => {
            for (let entry of entries) {
                const { width, height } = entry.contentRect;
                if (width > 0 && height > 0) {
                    initChart(width, height);
                    updateCalculations();
                }
            }
        });

        // Initialize App on Window Load
        window.onload = () => {
            setLanguage('en'); 
            resizeObserver.observe(container);
            animationFrameId = requestAnimationFrame(animate);
        };
    </script>

                            <li data-i18n="omegaDef"><span class="font-bold text-slate-800">&omega; : Angular Frequency</span> - Rotation speed (rad/s) = 2&pi;f</li>
                            <li data-i18n="freqDef"><span class="font-bold text-slate-800">f : Frequency</span> - Full cycles per second (Hz)</li>
                        </ul>
